{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || root.child('chatrooms').child($chatroomId).child('members').hasChild(auth.uid)",
        ".write": "$uid === auth.uid"
      }
    },
    "chatrooms": {
      ".read": "auth !== null",
      "$chatroomId": {
        ".write": "auth !== null && (!data.exists() || data.child('createdBy').val() === auth.uid)",
        "members": {
          "$uid": {
            ".write": "auth !== null && ($uid === auth.uid || data.parent().parent().child('createdBy').val() === auth.uid)"
          }
        }
      }
    },
    "messages": {
      "$chatroomId": {
        ".read": "auth !== null && root.child('chatrooms').child($chatroomId).child('members').hasChild(auth.uid)",
        ".write": "auth !== null && root.child('chatrooms').child($chatroomId).child('members').hasChild(auth.uid)"
      }
    }
  }
}